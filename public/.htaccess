Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^assets/.*\.php$ - [F,L]

  RewriteRule ^api/lead-webhook/?$ api/lead-webhook.php [L,QSA]
  RewriteRule ^api/workshop-webhook/?$ api/workshop-webhook.php [L,QSA]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^api/ - [R=404,L]

  RewriteRule ^ index.html [L]
</IfModule>

<FilesMatch "^(\.env|\.env\.php|composer\.(json|lock)|package(-lock)?\.json)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|gif|jpe?g|png|svg|webp|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(html|json|xml|txt)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
